#!/usr/bin/env sh
set -e

cargo fmt --all -- --check
cargo clippy --all-targets -- -D warnings

if command -v linecheck >/dev/null 2>&1; then
  linecheck .
elif cargo build --quiet 2>/dev/null; then
  ./target/debug/linecheck .
else
  echo "linecheck not found. Install it with: cargo install linecheck" >&2
  exit 1
fi

if command -v cargo-llvm-cov >/dev/null 2>&1; then
  cargo llvm-cov --fail-under-lines 100 --summary-only
else
  echo "cargo-llvm-cov not found; skipping coverage check." >&2
  echo "Install with: cargo install cargo-llvm-cov" >&2
fi
